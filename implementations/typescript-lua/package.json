{
  "name": "microverse",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=20.10.0"
  },
  "pnpm": {
    "overrides": {
      "handlebars": "^4.7.9",
      "vite": "^8.0.13"
    }
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:circular": "madge --circular --extensions ts --exclude dist packages",
    "build:pages": "node scripts/build-github-pages.mjs",
    "ci:microverse-lua": "turbo run build lint typecheck test --filter=@microverse.ts/microverse-lua...",
    "conformance:export": "tsx scripts/export-protocol-surfaces.mts",
    "codegen:examples": "pnpm exec microverse codegen --surface examples/sorting-lab/src/engine/sortingSurface.ts && pnpm exec microverse codegen --surface examples/chess-lab/src/engine/chessSurface.ts",
    "conformance": "node scripts/validate-conformance.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release:publish": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^9.27.0",
    "@microverse.ts/eslint-config": "workspace:*",
    "@microverse.ts/prettier-config": "workspace:*",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^9.27.0",
    "eslint-plugin-boundaries": "^5.0.1",
    "eslint-plugin-import-x": "^4.11.1",
    "madge": "^8.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.22.0",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vitest": "^3.1.4"
  }
}
