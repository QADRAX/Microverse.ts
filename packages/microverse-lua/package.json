{
  "name": "@microverse/microverse-lua",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "description": "Plug-and-play Lua microverse facade: Wasm VM, MicroverseLua, and re-exports for host surfaces and bridges.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@microverse/host-surface": "workspace:*",
    "@microverse/runtime-bridge": "workspace:*",
    "@microverse/runtime-capabilities": "workspace:*",
    "@microverse/runtime-core": "workspace:*",
    "@microverse/runtime-lua": "workspace:*",
    "@microverse/runtime-wasm": "workspace:*",
    "@microverse/runtime-zod": "workspace:*",
    "@microverse/shared": "workspace:*",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vitest": "^3.1.4"
  }
}
