{
  "name": "@microverse.ts/host-surface",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "description": "Declarative host surface (Zod + capabilities) → bridge tables and LuaDefManifest for .d.lua.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QADRAX/Microverse.ts.git",
    "directory": "packages/host-surface"
  },
  "bugs": "https://github.com/QADRAX/Microverse.ts/issues",
  "homepage": "https://github.com/QADRAX/Microverse.ts/tree/main/packages/host-surface",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
