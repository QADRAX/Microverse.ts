{
  "name": "@luarizer/host-surface",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "description": "Declarative host surface (Zod + capabilities) → bridge tables and LuarizerDefManifest for .d.lua.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@luarizer/lua-defs": "workspace:*",
    "@luarizer/runtime-bridge": "workspace:*",
    "@luarizer/runtime-capabilities": "workspace:*",
    "@luarizer/runtime-core": "workspace:*",
    "@luarizer/runtime-zod": "workspace:*",
    "@luarizer/shared": "workspace:*",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vitest": "^3.1.4"
  }
}
