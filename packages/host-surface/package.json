    "@microverse.ts/runtime-zod": "workspace:*",
    "@microverse.ts/shared": "workspace:*",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
