{
  "name": "@microverse.ts/lua-defs",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "Programmatic LuaCATS (.d.lua) generation from a Lua def manifest (no CLI).",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QADRAX/Luarizer.ts.git",
    "directory": "packages/lua-defs"
  },
  "bugs": "https://github.com/QADRAX/Luarizer.ts/issues",
  "homepage": "https://github.com/QADRAX/Luarizer.ts/tree/main/packages/lua-defs",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "schemas",
    "fixtures"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@microverse.ts/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
