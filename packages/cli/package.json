{
  "name": "@microverse/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "CLI for Microverse: per-runtime commands (e.g. generate-lua-defs for LuaCATS .d.lua).",
  "bin": {
    "microverse": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "test": "node -e \"process.exit(0)\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@microverse/lua-defs": "workspace:*",
    "tsx": "^4.19.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3"
  }
}
