{
  "name": "@luarizer/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "CLI for Luarizer (e.g. generate LuaCATS .d.lua for sandbox + bridges at build time).",
  "bin": {
    "luarizer": "./dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "test": "node -e \"process.exit(0)\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@luarizer/lua-defs": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3"
  }
}
